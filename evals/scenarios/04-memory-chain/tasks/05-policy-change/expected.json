{
  "test_cmd": "uv run python -m unittest discover -s . -p 'test_*.py'",
  "rules": [
    {
      "id": "canon_updated_to_50",
      "glob": "canon/*",
      "must_regex": "50",
      "description": "the new cap was recorded in the Canon"
    },
    {
      "id": "canon_no_stale_40",
      "glob": "canon/*",
      "forbid_regex": "40%|40 ?percent",
      "description": "the Canon no longer states the old cap as current"
    }
  ],
  "holdout": {
    "dir": "holdout",
    "test_cmd": "uv run python -m unittest holdout_t05"
  }
}
